# NVIDIA NIM API Configuration
# Dapatkan API key dari https://build.nvidia.com/
NVIDIA_NIM_API_KEY=your_nvidia_nim_api_key_here

# Model yang akan digunakan
# Pilihan tersedia: meta/llama-3.1-8b-instruct, meta/llama-3.1-70b-instruct, mistralai/mixtral-8x7b-instruct, dll.
NVIDIA_NIM_MODEL=qwen/qwen3.5-122b-a10b

# System prompt untuk chatbot (optional)
NVIDIA_NIM_SYSTEM_PROMPT=You are a helpful AI assistant.

# Cloudflare Account ID (untuk Vectorize - optional)
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id_here

# Cloudflare API Token (untuk Vectorize - optional)
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token_here

# Nama index Vectorize (optional)
VECTORIZE_INDEX_NAME=chatbot-search-index

# NVIDIA NIM Embedding Model (optional)
NVIDIA_NIM_EMBEDDING_MODEL=nvidia/nv-embedqa-e5-v5
